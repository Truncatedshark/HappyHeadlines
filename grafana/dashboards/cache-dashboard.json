{
  "title": "HappyHeadlines Cache",
  "uid": "happyheadlines-cache",
  "schemaVersion": 38,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Article Cache Hit Ratio",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(article_cache_hits_total[5m])) / (sum(rate(article_cache_hits_total[5m])) + sum(rate(article_cache_misses_total[5m])))",
          "legendFormat": "Hit ratio"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 2,
      "title": "Comment Cache Hit Ratio",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(comment_cache_hits_total[5m])) / (sum(rate(comment_cache_hits_total[5m])) + sum(rate(comment_cache_misses_total[5m])))",
          "legendFormat": "Hit ratio"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 3,
      "title": "Article Cache — Hits vs Misses",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(article_cache_hits_total[1m]))",
          "legendFormat": "Hits/s"
        },
        {
          "expr": "sum(rate(article_cache_misses_total[1m]))",
          "legendFormat": "Misses/s"
        }
      ],
      "datasource": "Prometheus"
    },
    {
      "id": 4,
      "title": "Comment Cache — Hits vs Misses",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(comment_cache_hits_total[1m]))",
          "legendFormat": "Hits/s"
        },
        {
          "expr": "sum(rate(comment_cache_misses_total[1m]))",
          "legendFormat": "Misses/s"
        }
      ],
      "datasource": "Prometheus"
    }
  ]
}
